# Local review artifacts / config
.review/telemetry.log

# Local benchmark API keys (never committed) - used only for a local benchmark run
*.keys.local
benchmark/.keys.local

# GitHub App credentials, if you ever use them
gha-creds-*.json

# Python bytecode (e.g. from running benchmark/score.py locally)
__pycache__/
*.pyc

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
